# Authentik environment variables.
# Used with: docker compose -f docker-compose.authentik.yml --env-file .env --env-file .env.authentik up -d
# Base values (POSTGRES_USER, POSTGRES_PASSWORD) come from .env.

# =============================================================================
# SECRET KEY — generate with: openssl rand -hex 50
# =============================================================================
AUTHENTIK_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_50  # pragma: allowlist secret
