# SequoIA Environment Configuration
# Copy this file to .env and update values for your deployment.
#
# For IMREDD deployment, see docs/DEPLOYMENT_IMREDD.md

# =============================================================================
# DEPLOYMENT
# =============================================================================
VERSION=v1.0.0
ENVIRONMENT=production
LOG_LEVEL=INFO

# =============================================================================
# DATA PATHS (persistent storage on host)
# =============================================================================
KAFKA_DATA_PATH=/mnt/kafka-data
CLICKHOUSE_DATA_PATH=/mnt/clickhouse-data
POSTGRES_DATA_PATH=/mnt/postgres-data
REDIS_DATA_PATH=/mnt/redis-data

# =============================================================================
# KAFKA
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
SCHEMA_REGISTRY_URL=http://schema-registry:8081
# External host for DAS hardware to connect (set to backend server IP)
KAFKA_EXTERNAL_HOST=192.168.99.113

# =============================================================================
# OPENTELEMETRY
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4317
PYTHONUNBUFFERED=1

# =============================================================================
# DAS PROCESSOR SETTINGS
# =============================================================================
DAS_FIBER_NAMES=carros
DAS_CHANNEL_COUNT=2829
DAS_SAMPLING_RATE_HZ=50
DAS_GENERATION_RATE_HZ=50
DAS_MEMORY_POOL_SIZE=10
DAS_CHANNEL_SLICE_STEP=2
DAS_FILTER_WARMUP_TIME_SECONDS=5.0
DAS_MAX_PROCESSING_RATE_HZ=50
DAS_PROCESSING_MEMORY_POOL_SIZE=5
DAS_STATE_CLEANUP_INTERVAL=300

# =============================================================================
# AI ENGINE
# =============================================================================
AI_MAX_CONCURRENT=10
ENABLE_COUNTING=true
AI_CORRELATION_THRESHOLD=130
FIBER_CONFIG_PATH=config/fibers.yaml
VISUALIZATION_OUTPUT=/app/visualizations

# =============================================================================
# CLICKHOUSE
# =============================================================================
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=sequoia
CLICKHOUSE_USER=sequoia
# Generate with: openssl rand -base64 24
CLICKHOUSE_PASSWORD=CHANGE_ME

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Generate with: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME

# =============================================================================
# POSTGRESQL
# =============================================================================
POSTGRES_DB=sequoia
POSTGRES_USER=sequoia
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# =============================================================================
# DJANGO BACKEND
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_64_CHAR_SECRET
DJANGO_ALLOWED_HOSTS=192.168.99.113,localhost
CORS_ALLOWED_ORIGINS=https://134.59.98.100
FRONTEND_URL=https://134.59.98.100

# Realtime data source: 'kafka' for production, 'simulation' for demos, 'auto' to detect
REALTIME_SOURCE=kafka

# =============================================================================
# JWT AUTHENTICATION (RS256)
# =============================================================================
# Generate keys with:
#   openssl genrsa 2048 > jwt_private.pem
#   openssl rsa -in jwt_private.pem -pubout > jwt_public.pem
#
# Option 1: Inline (replace newlines with \n)
JWT_SIGNING_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----
JWT_VERIFYING_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----
#
# Option 2: File paths (uncomment and set paths)
# JWT_SIGNING_KEY_FILE=/etc/sequoia/jwt_private.pem
# JWT_VERIFYING_KEY_FILE=/etc/sequoia/jwt_public.pem

# =============================================================================
# FRONTEND (build-time variables)
# =============================================================================
VITE_API_BASE_URL=http://192.168.99.113:8001
VITE_MAPBOX_TOKEN=pk.eyJ1Ijoic3lwaGVyciIsImEiOiJjbWcwOGZodHEwMnJyMmxzNnBveDdidWxsIn0.db7Lk0ON4mG1zqMVUZXMYg

# =============================================================================
# OPTIONAL: ALERTS & MONITORING
# =============================================================================
# Discord webhook for alerts
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Sentry error tracking
# SENTRY_DSN=https://your-key@sentry.io/your-project

# =============================================================================
# OPTIONAL: EMAIL (for password reset, notifications)
# =============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# OPTIONAL: PROXY (if behind corporate proxy)
# =============================================================================
# HTTP_PROXY=http://cache.unice.fr:8080
# HTTPS_PROXY=http://cache.unice.fr:8080
# NO_PROXY=localhost,127.0.0.1,192.168.99.113,192.168.99.110,kafka,redis,clickhouse,schema-registry,otel-lgtm
