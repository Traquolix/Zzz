# SequoIA Environment Configuration
# Copy this file to .env and update values for your deployment.
# Replace all CHANGE_ME values with real credentials before starting.

# =============================================================================
# DEPLOYMENT
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# =============================================================================
# DATA PATHS (persistent storage on host)
# =============================================================================
KAFKA_DATA_PATH=/mnt/kafka-data
CLICKHOUSE_DATA_PATH=/mnt/clickhouse-data
POSTGRES_DATA_PATH=/mnt/postgres-data
REDIS_DATA_PATH=/mnt/redis-data

# =============================================================================
# KAFKA
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
SCHEMA_REGISTRY_URL=http://schema-registry:8081
# External host for DAS hardware to connect (set to your backend server IP)
KAFKA_EXTERNAL_HOST=CHANGE_ME

# =============================================================================
# OPENTELEMETRY
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4317

# =============================================================================
# PIPELINE CONFIG
# =============================================================================
# All DAS processor and AI engine settings live in config/fibers.yaml.
# Only FIBER_ID (set per-container in docker-compose) and FIBER_CONFIG_PATH are env-driven.
FIBER_CONFIG_PATH=config/fibers.yaml

# =============================================================================
# CLICKHOUSE
# =============================================================================
# Use 'clickhouse' inside Docker, 'localhost' when running Django locally
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=sequoia
CLICKHOUSE_USER=sequoia
# Generate with: openssl rand -base64 24
CLICKHOUSE_PASSWORD=CHANGE_ME
# Read-only password for Grafana dashboards (separate from admin)
# Generate with: openssl rand -base64 24
CLICKHOUSE_GRAFANA_PASSWORD=CHANGE_ME

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Generate with: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME

# =============================================================================
# POSTGRESQL
# =============================================================================
POSTGRES_DB=sequoia
POSTGRES_USER=sequoia
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# =============================================================================
# DJANGO BACKEND
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_ALLOWED_HOSTS=localhost,CHANGE_ME
# Bind address for the backend API port (default: 127.0.0.1 = localhost only).
# Set to the server's internal IP if the reverse proxy is on a separate host.
# Set to 0.0.0.0 only if no reverse proxy is used (NOT recommended for production).
BACKEND_BIND_ADDRESS=127.0.0.1
CORS_ALLOWED_ORIGINS=https://CHANGE_ME
FRONTEND_URL=https://CHANGE_ME

# Realtime data source for the backend WebSocket server:
#   kafka  — Kafka bridge only (live DAS data)
#   sim    — simulation only (synthetic traffic for demos/dev)
#   both   — Kafka bridge + simulation side by side (enables live/sim toggle in UI)
#   auto   — probe Kafka: if reachable → both, otherwise → sim
REALTIME_SOURCE=kafka

# =============================================================================
# JWT AUTHENTICATION (RS256)
# =============================================================================
# The backend signs auth tokens with an RSA private key and verifies them with
# the matching public key. In dev mode, keys are auto-generated — you only need
# to set these for production.
#
# Generate a key pair:
#   openssl genrsa 2048 > secrets/jwt_private.pem
#   openssl rsa -in secrets/jwt_private.pem -pubout > secrets/jwt_public.pem
#
# Then either inline the keys (replace newlines with literal \n):
#   JWT_SIGNING_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...base64...\n-----END PRIVATE KEY-----
#   JWT_VERIFYING_KEY=-----BEGIN PUBLIC KEY-----\nMIIBI...base64...\n-----END PUBLIC KEY-----
#
# Or use file paths:
JWT_SIGNING_KEY_FILE=CHANGE_ME
JWT_VERIFYING_KEY_FILE=CHANGE_ME

# =============================================================================
# FRONTEND (build-time variables)
# =============================================================================
VITE_API_URL=http://CHANGE_ME:8001
VITE_MAPBOX_TOKEN=CHANGE_ME

# =============================================================================
# OPTIONAL: ALERTS & MONITORING
# =============================================================================
# Discord webhook for alerts
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Sentry error tracking (backend)
# SENTRY_DSN=https://your-key@sentry.io/your-project
# Sentry error tracking (frontend)
# VITE_SENTRY_DSN=https://your-key@sentry.io/your-frontend-project

# =============================================================================
# OPTIONAL: EMAIL (for password reset, notifications)
# =============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# OPTIONAL: PROXY (if behind corporate proxy)
# =============================================================================
# HTTP_PROXY=http://cache.unice.fr:8080
# HTTPS_PROXY=http://cache.unice.fr:8080
# NO_PROXY=localhost,127.0.0.1,192.168.1.100,192.168.1.101,kafka,redis,clickhouse,schema-registry,otel-lgtm
