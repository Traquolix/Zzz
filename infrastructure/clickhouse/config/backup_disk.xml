<?xml version="1.0"?>
<!-- ClickHouse backup disk — used by BACKUP/RESTORE commands.
     Mount a host directory at /backups in docker-compose.yml. -->
<clickhouse>
    <storage_configuration>
        <disks>
            <backups>
                <type>local</type>
                <path>/backups/</path>
            </backups>
        </disks>
    </storage_configuration>
    <backups>
        <allowed_disk>backups</allowed_disk>
        <allowed_path>/backups/</allowed_path>
    </backups>
</clickhouse>
