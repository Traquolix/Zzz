    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Messages consumed per second by the Processor (raw DAS data ingestion). If 0, the processor is dead or Kafka has no data.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0.0001 }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(messages_processed_total{service_name=~\"das-processor.*\"}[1m]))",
          "legendFormat": "msg/s",
          "refId": "A"
        }
      ],
      "title": "Processor",
      "type": "stat"
    },
    {
